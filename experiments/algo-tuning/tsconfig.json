{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "rootDir": "../..",
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",
